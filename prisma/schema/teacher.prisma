model Teacher {
  id              Int       @id @default(autoincrement())
  firstName       String
  middleName      String?
  lastName        String
  email           String?   @unique
  contactNumber   String    @unique
  gradeLevel      String
  dateOfBirth     DateTime
  age             Int
  gender          String
  civilStatus     String
  dateHired       DateTime
  lengthOfService Int
  adviserId       Int?      @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  avatar          String
  subjects        Subject[]
  advisorySection Section?  @relation(fields: [adviserId], references: [id])
  isOjt           Boolean   @default(false)
  height          String?
  weight          String?
  bloodType       String?
  religion        String?
  nationality     String?
  address         Address?  @relation(fields: [teacherId], references: [id])
  teacherId       Int?      @unique
  benefits        Benefits? @relation(fields: [benefitsId], references: [id])
  benefitsId      Int?      @unique
  citizenship     Json      @default("{}")
}
